// Prisma schema for darvinyi-debate
//
// References:
//   /context/AGENT_SPEC.md   — agent roster and identity fields
//   /context/ELO_SPEC.md     — rating system (Agent.elo, EloChange)
//   /context/JUDGE_SPEC.md   — evaluation score structure
//   /context/DEBATE_FORMAT.md — turn structure (6 rounds, side, content)
//
// All IDs are strings. Agent IDs are stable human-readable slugs (e.g. "claude-opus-4-7").
// All other IDs are cuids.
//
// Matches are two-sided: each match consists of two legs. In leg 1, agent A
// takes affirmative and agent B takes negative. In leg 2, they swap. Each leg
// is judged independently; the match winner is computed by summing the judge's
// per-leg scores across both legs.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================================
// Agent
// ----------------------------------------------------------------------------
// A debater. One row per (provider, model) combination in the roster.
// id is a stable human-readable slug — used as the primary key so it can be
// referenced from URLs (e.g. /agent/claude-opus-4-7) and code without an
// indirection through a numeric id.
// ============================================================================

model Agent {
  id          String   @id
  displayName String
  provider    String
  modelId     String
  elo         Float    @default(1200)
  wins        Int      @default(0)
  losses      Int      @default(0)
  draws       Int      @default(0)
  createdAt   DateTime @default(now())

  aDebates   Debate[]    @relation("A")
  bDebates   Debate[]    @relation("B")
  eloChanges EloChange[]
}

// ============================================================================
// Debate
// ----------------------------------------------------------------------------
// One match. Two agents, one topic, two legs of six turns each.
// status: 'pending' → 'in_progress' → 'judging' → 'completed' (or 'failed').
// winner is null until both legs are judged + scores summed; then 'A', 'B',
// or 'draw' — the agent-level match outcome (not a position).
// ============================================================================

model Debate {
  id           String    @id @default(cuid())
  topic        String
  status       String    @default("pending")
  agentAId     String
  agentBId     String
  agentA       Agent     @relation("A", fields: [agentAId], references: [id])
  agentB       Agent     @relation("B", fields: [agentBId], references: [id])
  winner       String?
  errorMessage String?
  createdAt    DateTime  @default(now())
  completedAt  DateTime?

  turns       DebateTurn[]
  evaluations Evaluation[]
  eloChanges  EloChange[]

  @@index([createdAt])
  @@index([status])
  @@index([completedAt])
}

// ============================================================================
// DebateTurn
// ----------------------------------------------------------------------------
// One round of one leg. Always 12 turns per completed debate: 6 per leg.
// leg ∈ {1, 2}. roundNumber ∈ {1..6}.
// side is the POSITION taken in this leg ('aff' or 'neg') — not an agent id.
// ============================================================================

model DebateTurn {
  id          String   @id @default(cuid())
  debateId    String
  debate      Debate   @relation(fields: [debateId], references: [id], onDelete: Cascade)
  leg         Int
  roundNumber Int
  roundName   String
  side        String
  content     String   @db.Text
  toolCalls   Json?
  tokensIn    Int?
  tokensOut   Int?
  durationMs  Int?
  createdAt   DateTime @default(now())

  @@unique([debateId, leg, roundNumber])
  @@index([debateId, leg, roundNumber])
}

// ============================================================================
// Evaluation
// ----------------------------------------------------------------------------
// The judge's verdict for ONE leg. Two rows per completed debate (one per leg).
// winner is the per-leg position winner ('aff' | 'neg' | 'draw') — anonymized.
// The agent-level match outcome lives on Debate.winner and is computed by
// summing affTotal + negTotal across both legs.
// ============================================================================

model Evaluation {
  id            String   @id @default(cuid())
  debateId      String
  debate        Debate   @relation(fields: [debateId], references: [id], onDelete: Cascade)
  leg           Int
  winner        String
  affArgument   Float
  affEvidence   Float
  affResponsive Float
  affPersuasion Float
  affTotal      Float
  negArgument   Float
  negEvidence   Float
  negResponsive Float
  negPersuasion Float
  negTotal      Float
  reasoning     String   @db.Text
  judgeModel    String

  // Human vote (agreement-tracking only — does not affect match outcome or ELO).
  humanWinner          String?
  humanVotedAt         DateTime?
  humanAgreedWithJudge Boolean?

  createdAt DateTime @default(now())

  @@unique([debateId, leg])
}

// ============================================================================
// EloChange
// ----------------------------------------------------------------------------
// One row per agent per match. Captures before/after/delta so an agent's
// ELO trajectory can be rendered as a line chart on the profile page.
// ============================================================================

model EloChange {
  id        String   @id @default(cuid())
  agentId   String
  agent     Agent    @relation(fields: [agentId], references: [id])
  debateId  String
  debate    Debate   @relation(fields: [debateId], references: [id], onDelete: Cascade)
  before    Float
  after     Float
  delta     Float
  createdAt DateTime @default(now())

  @@index([agentId, createdAt])
  @@index([debateId])
}
