// Prisma schema for darvinyi-debate
//
// References:
//   /context/AGENT_SPEC.md   — agent roster and identity fields
//   /context/ELO_SPEC.md     — rating system (Agent.elo, EloChange)
//   /context/JUDGE_SPEC.md   — evaluation score structure
//   /context/DEBATE_FORMAT.md — turn structure (6 rounds, side, content)
//
// All IDs are strings. Agent IDs are stable human-readable slugs (e.g. "claude-opus-4-7").
// All other IDs are cuids.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================================
// Agent
// ----------------------------------------------------------------------------
// A debater. One row per (provider, model) combination in the roster.
// id is a stable human-readable slug — used as the primary key so it can be
// referenced from URLs (e.g. /agent/claude-opus-4-7) and code without an
// indirection through a numeric id.
// ============================================================================

model Agent {
  id          String   @id
  displayName String
  provider    String
  modelId     String
  elo         Float    @default(1200)
  wins        Int      @default(0)
  losses      Int      @default(0)
  draws       Int      @default(0)
  createdAt   DateTime @default(now())

  affDebates Debate[]    @relation("Affirmative")
  negDebates Debate[]    @relation("Negative")
  eloChanges EloChange[]
}

// ============================================================================
// Debate
// ----------------------------------------------------------------------------
// One debate session. Two agents, one topic, six turns.
// status: 'pending' → 'in_progress' → 'completed' (or 'failed' on error)
// winner is null until the judge finishes; then 'aff', 'neg', or 'draw'.
// errorMessage is populated only for failed debates (e.g. judge JSON parse
// failure after retry).
// ============================================================================

model Debate {
  id           String    @id @default(cuid())
  topic        String
  status       String    @default("pending")
  affAgentId   String
  negAgentId   String
  affAgent     Agent     @relation("Affirmative", fields: [affAgentId], references: [id])
  negAgent     Agent     @relation("Negative", fields: [negAgentId], references: [id])
  winner       String?
  errorMessage String?
  createdAt    DateTime  @default(now())
  completedAt  DateTime?

  turns      DebateTurn[]
  evaluation Evaluation?
  eloChanges EloChange[]

  @@index([createdAt])
  @@index([status])
  @@index([completedAt])
}

// ============================================================================
// DebateTurn
// ----------------------------------------------------------------------------
// One round of a debate. Always 6 turns per completed debate, ordered by
// roundNumber 1..6.
// toolCalls is a JSON array of { tool, input, outputSummary } objects, captured
// from the AgentRunner event stream.
// content is the final accumulated text of the turn — what the judge sees.
// ============================================================================

model DebateTurn {
  id          String   @id @default(cuid())
  debateId    String
  debate      Debate   @relation(fields: [debateId], references: [id], onDelete: Cascade)
  roundNumber Int
  roundName   String
  side        String
  content     String   @db.Text
  toolCalls   Json?
  tokensIn    Int?
  tokensOut   Int?
  durationMs  Int?
  createdAt   DateTime @default(now())

  @@index([debateId, roundNumber])
}

// ============================================================================
// Evaluation
// ----------------------------------------------------------------------------
// The judge's verdict. One per completed debate (unique on debateId).
// Scores are stored individually so the UI can render per-axis bars and so
// future analyses can dig into specific dimensions.
// Totals (affTotal, negTotal) are computed by the judge module and stored
// for convenience.
// ============================================================================

model Evaluation {
  id            String   @id @default(cuid())
  debateId      String   @unique
  debate        Debate   @relation(fields: [debateId], references: [id], onDelete: Cascade)
  winner        String
  affArgument   Float
  affEvidence   Float
  affResponsive Float
  affPersuasion Float
  affTotal      Float
  negArgument   Float
  negEvidence   Float
  negResponsive Float
  negPersuasion Float
  negTotal      Float
  reasoning     String   @db.Text
  judgeModel    String

  // Human vote (optional override of the judge's verdict)
  humanWinner          String?
  humanVotedAt         DateTime?
  humanAgreedWithJudge Boolean?

  createdAt     DateTime @default(now())
}

// ============================================================================
// EloChange
// ----------------------------------------------------------------------------
// One row per agent per debate. Captures the before/after/delta so an agent's
// ELO trajectory can be rendered as a line chart on the profile page.
// ============================================================================

model EloChange {
  id        String   @id @default(cuid())
  agentId   String
  agent     Agent    @relation(fields: [agentId], references: [id])
  debateId  String
  debate    Debate   @relation(fields: [debateId], references: [id], onDelete: Cascade)
  before    Float
  after     Float
  delta     Float
  createdAt DateTime @default(now())

  @@index([agentId, createdAt])
  @@index([debateId])
}
