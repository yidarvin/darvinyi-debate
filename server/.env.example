# Database connection — Railway provides this automatically in production.
# For local dev, point to a local PostgreSQL instance.
DATABASE_URL=postgresql://localhost:5432/darvinyi_debate

# Server config
PORT=3001
NODE_ENV=development

# LLM provider API keys — all required
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=
XAI_API_KEY=

# Auth — required to POST a new debate. Pick something strong.
DEBATE_KEYPHRASE=change_me_before_deploying

# Optional — override path to client build (defaults to ../client/dist relative to server cwd)
# CLIENT_DIST_PATH=../client/dist
