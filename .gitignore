# Dependencies
node_modules/

# Build output
dist/
build/
.vite/

# Environment files — never commit actual secrets
.env
.env.local
.env.*.local

# But DO commit .env.example and .env.production (production-public config)
!.env.example
!.env.production

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# OS / editor
.DS_Store
.vscode/
.idea/
*.swp
*.swo

# Coverage
coverage/
.nyc_output/

# Prisma — track migrations, not the dev SQLite database
*.db
*.db-journal

# Misc
*.tsbuildinfo
.cache/
